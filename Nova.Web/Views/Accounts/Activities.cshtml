@model List<Nova.Web.ViewModels.ActivityViewModel>

@{
    ViewData["Title"] = "User Activities";
}

<script src="@Url.Content("~/lib/jquery/dist/jquery.min.js")"></script>


<div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="toast-header">
            <strong class="me-auto">Alert</strong>
            <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
        <div id="toastmessage" class="toast-body">
        </div>
    </div>
</div>
<div class="app-content-holder general-gaping ">
    <div class="row ">

        <!-- BEGIN col-12 -->
        <div class="col-xl-12">

            <!-- BEGIN #responsiveTables -->
            <div id="responsiveTables" class="mb-5 ">
                @if (Model != null && Model.Count > 0)
                {

                    <div class="card card-general-table">
                        <div class="card-body px-0 py-0">
                            <div class="table-responsive">

                                <table class="table table-firstRow mb-0">
                                    <thead>
                                        <tr>
                                            <th scope="col"></th>
                                            <th scope="col">Name</th>
                                            <th scope="col">Username</th>
                                            <th scope="col">Description</th>
                                            <th scope="col">Date</th>                                            
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (Nova.Web.ViewModels.ActivityViewModel item in Model)
                                        {                                           
                                            <tr>
                                                <th scope="row"></th>
                                                <td>@item.FullName</td>
                                                <td>@item.Username</td>
                                                <td>@item.Description</td>
                                                <td>@item.CreatedDate.ToString("MM-dd-yyyy HH:mm:ss")</td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>

                            </div>



                        </div>
                    </div>

                }
            </div>

        </div>
        <!-- END #responsiveTables -->

    </div>
</div>
