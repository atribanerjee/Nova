@model Nova.Web.ViewModels.UserViewModel
@{
    ViewData["Title"] = "Edit User";
}


<form asp-action="Edit" asp-controller="Accounts" method="POST" data-ajax="true" data-ajax-update="result" asp-antiforgery="true" data-ajax-success="success">
    @Html.HiddenFor(m => Model.Id)
    <div class="col-4">
        <label class="form-label">First Name</label>
        @Html.TextBoxFor(m => m.Firstname, new { @class = "form-control", @placeholder = "First Name" })
        @Html.ValidationMessageFor(m => m.Firstname, "", new { @class = "text-danger" })
    </div>
    <div class="col-4">
        <label class="form-label">Last Name</label>
        @Html.TextBoxFor(m => m.Lastname, new { @class = "form-control", @placeholder = "Last Name" })
        @Html.ValidationMessageFor(m => m.Lastname, "", new { @class = "text-danger" })
    </div>
    <div class="col-4">
        <label class="form-label">Username</label>
        @Html.TextBoxFor(m => m.Username, new { @class = "form-control", @placeholder = "Username", @readonly = "true" })
        @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
    </div>
    <div class="col-4">
        <label class="form-label">Email</label>
        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", @placeholder = "Email", @readonly = "true" })
        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
    </div>
    <div class="col-4">
        <label class="form-label">Phone</label>
        @Html.TextBoxFor(m => m.Phone, new { @class = "form-control", @placeholder = "Phone", @maxlength = 12 })
    </div>
    <div class="col-4">
        <label class="form-label">Role</label>
        @Html.DropDownListFor(m => m.RoleId, Model.ddlRoles, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.RoleId, "", new { @class = "text-danger" })
    </div>
    <div class="col-12  pt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <button type="button" onclick="window.location.href='/Accounts/UserList'" id="kt_login_reset_cancel" class="btn btn-danger"> Cancel </button>
    </div>
</form>


